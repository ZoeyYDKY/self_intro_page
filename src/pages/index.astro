---
import Layout from "../layouts/Layout.astro";
import ResumeContent from "../content/resume.md";
import { getCollection } from "astro:content";
import siteConfig from "../site.config";
import { articles } from "../data/articles";
import { gallery } from "../data/gallery";

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\//, "")}`;

const projectEntries = await getCollection("projects");
const projects = await Promise.all(
  projectEntries.map(async (project) => {
    const rendered = await project.render();

    return {
      ...project.data,
      Content: rendered.Content,
    };
  }),
);

projects.sort((left, right) => {
  return new Date(right.date).getTime() - new Date(left.date).getTime();
});

const sectionTabs = [
  { id: "home", label: "首页" },
  { id: "resume", label: "简历" },
  { id: "projects", label: "项目" },
  { id: "hobbies", label: "兴趣" },
  { id: "gallery", label: "相册" },
  { id: "writing", label: "专栏" },
  { id: "links", label: "链接" },
];
---

<Layout title={`${siteConfig.name} | 个人网站`} description={siteConfig.summary}>
  <div
    class="mobile-tabs"
    role="tablist"
    aria-label="栏目切换"
    style={`--tab-count: ${sectionTabs.length};`}
  >
    {sectionTabs.map((tab, idx) => (
      <button
        class="mobile-tab"
        data-swipe-tab={tab.id}
        role="tab"
        aria-selected={idx === 0 ? "true" : "false"}
      >
        {tab.label}
      </button>
    ))}
    <div class="mobile-tab-progress" aria-hidden="true">
      <span class="mobile-tab-progress-thumb" data-tab-progress-thumb></span>
    </div>
  </div>

  <div class="swipe-stage">
    <button
      type="button"
      class="swipe-nav-btn swipe-nav-btn--prev"
      data-swipe-prev
      aria-label="上一栏目"
    >
      <span class="swipe-nav-icon" aria-hidden="true">›</span>
    </button>
    <button
      type="button"
      class="swipe-nav-btn swipe-nav-btn--next"
      data-swipe-next
      aria-label="下一栏目"
    >
      <span class="swipe-nav-icon" aria-hidden="true">›</span>
    </button>
    <div class="swipe-deck" data-swipe-deck>
    <section class="section swipe-panel hero" id="home" data-swipe-panel>
      <div class="hero-media">
        <img
          class="avatar"
          src={asset(siteConfig.avatarUrl)}
          alt={`${siteConfig.name} avatar`}
          loading="eager"
        />
      </div>

      <div class="hero-copy">
        <p class="eyebrow">Personal site · Manus-inspired layout</p>
        <h1>{siteConfig.name}</h1>
        <p>{siteConfig.tagline}</p>
        <p>{siteConfig.summary}</p>

        <div class="hero-actions">
          {siteConfig.githubUrl ? (
            <a class="button" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
              查看 GitHub
            </a>
          ) : (
            <a class="button" href={`mailto:${siteConfig.email}`}>
              联系邮箱
            </a>
          )}
          <button class="button secondary" data-jump-tab="projects" type="button">
            浏览项目
          </button>
        </div>

        <div class="hero-meta">
          <span class="tag">{siteConfig.location}</span>
          <span class="tag">数据科学</span>
          <span class="tag">LLM · Agent</span>
        </div>
      </div>
    </section>

    <section class="section swipe-panel" id="resume" data-swipe-panel>
      <div class="section-header section-header--decorated section-header--blob-resume">
        <div class="section-header__decor" aria-hidden="true">
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
        </div>
        <p class="eyebrow">Resume</p>
        <h2>个人简历</h2>
      </div>

      <div class="panel rich-text">
        <ResumeContent />
      </div>
    </section>

    <section class="section swipe-panel" id="projects" data-swipe-panel>
      <div class="section-header section-header--decorated section-header--blob-projects">
        <div class="section-header__decor" aria-hidden="true">
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
        </div>
        <p class="eyebrow">Projects</p>
        <h2>项目经验</h2>
      </div>

      <div class="cards">
        {projects.map((project) => (
          <article class="project-card">
            <div class="card-topline">
              <span>{project.date}</span>
              {project.link ? (
                <a class="text-link" href={project.link} target="_blank" rel="noreferrer">
                  查看项目
                </a>
              ) : (
                <span class="card-note">暂无公开链接</span>
              )}
            </div>
            <h3>{project.title}</h3>
            <div class="rich-text">
              <project.Content />
            </div>
            <div class="tag-list">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section swipe-panel" id="hobbies" data-swipe-panel>
      <div class="section-header section-header--decorated section-header--blob-hobbies">
        <div class="section-header__decor" aria-hidden="true">
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
        </div>
        <p class="eyebrow">Life</p>
        <h2>兴趣爱好</h2>
      </div>

      <div class="panel hobbies-panel">
        <ul class="hobbies-list">
          {siteConfig.hobbies.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section swipe-panel" id="gallery" data-swipe-panel>
      <div class="section-header section-header--decorated section-header--blob-gallery">
        <div class="section-header__decor" aria-hidden="true">
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
        </div>
        <p class="eyebrow">Gallery</p>
        <h2>生活剪影</h2>
        <p class="section-intro">一些与工作无关的瞬间，之后可以换成自己的照片。</p>
      </div>

      <div class="gallery-grid">
        {gallery.map((item) => (
          <figure class="gallery-item">
            {item.src ? (
              <img
                class="gallery-img"
                src={asset(item.src)}
                alt={item.alt}
                loading="lazy"
              />
            ) : (
              <div class="gallery-placeholder" role="img" aria-label={item.alt}>
                <span class="gallery-placeholder-dot" aria-hidden="true" />
                <span class="gallery-placeholder-text">待上传照片</span>
              </div>
            )}
            {item.caption ? <figcaption class="gallery-caption">{item.caption}</figcaption> : null}
          </figure>
        ))}
      </div>
    </section>

    <section class="section swipe-panel" id="writing" data-swipe-panel>
      <div class="section-header section-header--decorated section-header--blob-writing">
        <div class="section-header__decor" aria-hidden="true">
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
        </div>
        <p class="eyebrow">Writing</p>
        <h2>专栏文章</h2>
      </div>

      {articles.length === 0 ? (
        <p class="section-intro section-intro--flush">
          暂无外链文章；有内容后会在此列出标题与入口。
        </p>
      ) : (
        <div class="cards">
          {articles.map((article) => (
            <article class="article-card">
              <div class="card-topline">
                <span>{article.platform ?? "专栏"}</span>
                <span>{article.date ?? "持续更新"}</span>
              </div>
              <h3>
                <a href={article.url} target="_blank" rel="noreferrer">
                  {article.title}
                </a>
              </h3>
              <a class="text-link" href={article.url} target="_blank" rel="noreferrer">
                打开文章
              </a>
            </article>
          ))}
        </div>
      )}
    </section>

    <section class="section swipe-panel" id="links" data-swipe-panel>
      <div class="section-header section-header--decorated section-header--blob-links">
        <div class="section-header__decor" aria-hidden="true">
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
          <span class="section-header__blob"></span>
        </div>
        <p class="eyebrow">Links</p>
        <h2>公开链接</h2>
      </div>

      <div class="links-grid">
        {siteConfig.githubUrl ? (
          <a class="link-card" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
            <strong>GitHub</strong>
            <p>{siteConfig.githubUrl}</p>
          </a>
        ) : null}
        <a class="link-card" href={`mailto:${siteConfig.email}`}>
          <strong>Email</strong>
          <p>{siteConfig.email}</p>
        </a>
      </div>
    </section>
    </div>
  </div>

  <script is:inline>
    (() => {
      const deck = document.querySelector("[data-swipe-deck]");
      const tabs = Array.from(document.querySelectorAll("[data-swipe-tab]"));
      const jumpButtons = Array.from(document.querySelectorAll("[data-jump-tab]"));
      const progressThumb = document.querySelector("[data-tab-progress-thumb]");
      const btnPrev = document.querySelector("[data-swipe-prev]");
      const btnNext = document.querySelector("[data-swipe-next]");
      const tabsBar = document.querySelector(".mobile-tabs");
      if (!deck || tabs.length === 0) return;

      const panelIndex = new Map();
      tabs.forEach((tab, idx) => panelIndex.set(tab.dataset.swipeTab, idx));
      const panels = Array.from(document.querySelectorAll("[data-swipe-panel]"));
      let activeTabIndex = 0;

      const updateProgress = () => {
        if (!progressThumb || !progressThumb.parentElement) return;
        const maxScroll = Math.max(deck.scrollWidth - deck.clientWidth, 1);
        const ratio = Math.min(1, Math.max(0, deck.scrollLeft / maxScroll));
        const track = progressThumb.parentElement;
        const maxLeft = Math.max(track.clientWidth - progressThumb.clientWidth, 0);
        progressThumb.style.transform = `translateX(${ratio * maxLeft}px)`;
      };

      const updatePanelEffects = () => {
        if (panels.length === 0 || deck.clientWidth === 0) return;
        const activeFloat = deck.scrollLeft / deck.clientWidth;
        panels.forEach((panel, idx) => {
          const distance = Math.min(Math.abs(activeFloat - idx), 1.2);
          const emphasis = Math.max(0, 1 - distance);
          panel.style.setProperty("--panel-emphasis", emphasis.toFixed(3));
        });
      };

      const setActive = (idx) => {
        const safeIdx = Math.max(0, Math.min(idx, tabs.length - 1));
        if (safeIdx === activeTabIndex) return;
        tabs[activeTabIndex]?.setAttribute("aria-selected", "false");
        tabs[safeIdx]?.setAttribute("aria-selected", "true");
        activeTabIndex = safeIdx;
      };

      const syncNavButtons = (idx) => {
        const safeIdx = Math.max(0, Math.min(idx, tabs.length - 1));
        if (btnPrev) {
          btnPrev.disabled = safeIdx <= 0;
        }
        if (btnNext) {
          btnNext.disabled = safeIdx >= tabs.length - 1;
        }
      };

      const goTo = (idx, smooth = true) => {
        const safeIdx = Math.max(0, Math.min(idx, tabs.length - 1));
        const left = deck.clientWidth * safeIdx;
        deck.scrollTo({ left, behavior: smooth ? "smooth" : "auto" });
        setActive(safeIdx);
        updateProgress();
        syncNavButtons(safeIdx);
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const idx = panelIndex.get(tab.dataset.swipeTab);
          if (typeof idx === "number") goTo(idx);
        });
      });

      jumpButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const idx = panelIndex.get(btn.dataset.jumpTab);
          if (typeof idx === "number") goTo(idx);
        });
      });

      btnPrev?.addEventListener("click", () => {
        const idx = Math.round(deck.scrollLeft / deck.clientWidth);
        goTo(idx - 1);
      });
      btnNext?.addEventListener("click", () => {
        const idx = Math.round(deck.scrollLeft / deck.clientWidth);
        goTo(idx + 1);
      });

      let ticking = false;
      let tabsState = "base";
      let tabsRaf = 0;
      const updateFromScroll = () => {
        const idx = Math.round(deck.scrollLeft / deck.clientWidth);
        setActive(idx);
        updateProgress();
        updatePanelEffects();
        syncNavButtons(idx);
      };

      const updateTabsVisualByScroll = () => {
        if (!tabsBar) return;
        const lifted = window.scrollY > 24;
        const nextState = lifted ? "lifted" : "base";
        if (nextState === tabsState) return;
        tabsState = nextState;
        tabsBar.setAttribute("data-scroll-state", tabsState);
      };

      deck.addEventListener(
        "scroll",
        () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            updateFromScroll();
            ticking = false;
          });
        },
        { passive: true },
      );

      // Desktop drag with inertia + damping (touch devices use native momentum).
      let dragging = false;
      let startX = 0;
      let startScroll = 0;
      let lastScroll = 0;
      let lastTime = 0;
      let velocity = 0;
      let inertiaRaf = 0;

      const stopInertia = () => {
        if (!inertiaRaf) return;
        cancelAnimationFrame(inertiaRaf);
        inertiaRaf = 0;
      };

      const runInertia = () => {
        const maxScroll = Math.max(deck.scrollWidth - deck.clientWidth, 0);
        const step = () => {
          velocity *= 0.93;
          if (Math.abs(velocity) < 0.02) {
            inertiaRaf = 0;
            goTo(Math.round(deck.scrollLeft / deck.clientWidth));
            return;
          }

          let next = deck.scrollLeft + velocity * 16;
          if (next < 0) {
            next *= 0.42;
            velocity *= 0.72;
          } else if (next > maxScroll) {
            next = maxScroll + (next - maxScroll) * 0.42;
            velocity *= 0.72;
          }
          deck.scrollLeft = next;
          updateFromScroll();
          inertiaRaf = requestAnimationFrame(step);
        };
        inertiaRaf = requestAnimationFrame(step);
      };

      deck.addEventListener("pointerdown", (evt) => {
        if (evt.pointerType === "touch" || evt.button !== 0) return;
        dragging = true;
        deck.setPointerCapture(evt.pointerId);
        stopInertia();
        startX = evt.clientX;
        startScroll = deck.scrollLeft;
        lastScroll = deck.scrollLeft;
        lastTime = performance.now();
        velocity = 0;
      });

      deck.addEventListener("pointermove", (evt) => {
        if (!dragging) return;
        const maxScroll = Math.max(deck.scrollWidth - deck.clientWidth, 0);
        const delta = evt.clientX - startX;
        let target = startScroll - delta * 1.08;
        if (target < 0) {
          target *= 0.35;
        } else if (target > maxScroll) {
          target = maxScroll + (target - maxScroll) * 0.35;
        }
        deck.scrollLeft = target;

        const now = performance.now();
        const dt = Math.max(now - lastTime, 1);
        velocity = (deck.scrollLeft - lastScroll) / dt;
        lastScroll = deck.scrollLeft;
        lastTime = now;
        updateFromScroll();
      });

      const onDragEnd = () => {
        if (!dragging) return;
        dragging = false;
        runInertia();
      };

      deck.addEventListener("pointerup", onDragEnd);
      deck.addEventListener("pointercancel", onDragEnd);
      deck.addEventListener("pointerleave", onDragEnd);

      window.addEventListener("resize", () => {
        goTo(activeTabIndex, false);
      });

      window.addEventListener(
        "scroll",
        () => {
          if (tabsRaf) return;
          tabsRaf = requestAnimationFrame(() => {
            updateTabsVisualByScroll();
            tabsRaf = 0;
          });
        },
        { passive: true },
      );

      updateFromScroll();
      updateTabsVisualByScroll();
    })();
  </script>
</Layout>
